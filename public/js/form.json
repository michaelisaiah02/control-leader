            "name": "shift",
            "options": [
                "1",
                "2",
                "3"
            ]
        },
        {
            "id": "operator",
            "label": "ID & Nama Operator",
            "type": "select",
            "name": "operator",
            "options": [
                "OP001 - Budi",
                "OP002 - Andi",
                "OP003 - Siti"
            ]
        },
        {
            "id": "bagian",
            "label": "Bagian",
            "type": "text",
            "name": "bagian",
            "placeholder": "Masukkan Bagian"
        }
    ],
    "bagianA_2": [
        {
            "id": "kehadiran",
