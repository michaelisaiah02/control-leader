                    },
                    {
                        "id": "bagian_pengganti",
                        "label": "Bagian Operator Pengganti",
                        "type": "text",
                        "placeholder": "Contoh: Finishing",
                        "name": "bagian_pengganti"
                    },
                    {
                        "id": "kondisi_pengganti",
                        "label": "Kondisi Operator Pengganti",
                        "type": "radio",
                        "name": "kondisi_pengganti",
                        "options": [
                            "Sehat",
                            "Sakit"
                        ]
                    }
                ],
                "1) Hadir": [
                    {
                        "id": "kondisi",
                        "label": "Kondisi Operator",
                        "type": "radio",
                        "name": "kondisi",
                        "options": [
                            "Sehat",
                            "Sakit"
                        ]
                    }
                ]
